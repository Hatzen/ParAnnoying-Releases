<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content" >

    <TextView
        android:id="@+id/receiver_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Very long Username"
        android:layout_alignParentStart="true"
        android:layout_toStartOf="@id/messageCount"
        android:layout_marginTop="9dp"
        android:layout_marginLeft="9dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textSize="20sp" >
    </TextView>

    <com.mikepenz.iconics.view.IconicsTextView
        android:id="@+id/messageCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimaryDark"
        android:textColor="@color/light_gray"
        android:layout_centerHorizontal="true"
        android:layout_toStartOf="@id/event_time"
        android:layout_alignTop="@id/receiver_name"
        android:layout_marginBottom="10dp"
        android:paddingLeft="15dp"
        android:paddingRight="15dp"
        android:paddingBottom="5dp"
        android:paddingTop="5dp"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:text="6 Messages" />

    <com.mikepenz.iconics.view.IconicsTextView
        android:text="17:51  21.05.2021"
        android:textColor="@color/colorAccent"
        android:id="@+id/event_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="100dp"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="9dp"
        android:layout_marginEnd="5dp"
        android:textSize="12sp">
    </com.mikepenz.iconics.view.IconicsTextView>


    <com.mikepenz.iconics.view.IconicsTextView
        android:id="@+id/message_text"
        android:maxLines="3"
        android:ellipsize="end"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/receiver_name"
        android:text="Some (File-)Message"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="4dp"
        android:layout_marginLeft="9dp"
        android:textSize="16sp" >
    </com.mikepenz.iconics.view.IconicsTextView>
</RelativeLayout>