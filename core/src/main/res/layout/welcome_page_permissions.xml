<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    android:gravity="center"
    android:orientation="vertical">

    <LinearLayout
        android:layout_height="wrap_content"
        android:layout_width="match_parent"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/welcomeHeading"
            android:layout_margin="25dp"
            android:textColor="@color/colorWhite"
            android:textSize="28sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_above="@+id/welcomeText"
            android:gravity="center"
            android:layout_weight="1"/>
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatImageButton
        android:layout_margin="10dp"
        android:padding="10dp"
        android:id="@+id/permission_camera"
        android:layout_width="125dp"
        android:layout_height="50dp"
        android:background="@drawable/button_shape"
        android:scaleType="fitCenter"
        android:textColor="@color/colorWhite"
        android:layout_alignBottom="@+id/welcomeHeading"/>
    <androidx.appcompat.widget.AppCompatImageButton
        android:layout_margin="10dp"
        android:padding="10dp"
        android:id="@+id/permission_storage"
        android:layout_width="125dp"
        android:layout_height="50dp"
        android:background="@drawable/button_shape"
        android:scaleType="fitCenter"
        android:textColor="@color/colorWhite"
        android:layout_alignBottom="@+id/welcomeHeading"/>
    <androidx.appcompat.widget.AppCompatImageButton
        android:layout_margin="10dp"
        android:padding="10dp"
        android:id="@+id/permission_phone"
        android:layout_width="125dp"
        android:layout_height="50dp"
        android:background="@drawable/button_shape"
        android:scaleType="fitCenter"
        android:textColor="@color/colorWhite"
        android:layout_alignBottom="@+id/welcomeHeading"/>
    <androidx.appcompat.widget.AppCompatImageButton
        android:layout_margin="10dp"
        android:padding="10dp"
        android:id="@+id/permission_location"
        android:layout_width="125dp"
        android:layout_height="50dp"
        android:background="@drawable/button_shape"
        android:scaleType="fitCenter"
        android:textColor="@color/colorWhite"
        android:layout_alignBottom="@+id/welcomeHeading"/>
    <androidx.appcompat.widget.AppCompatImageButton
        android:layout_margin="10dp"
        android:padding="10dp"
        android:id="@+id/permission_coarse_location"
        android:layout_width="125dp"
        android:layout_height="50dp"
        android:background="@drawable/button_shape"
        android:scaleType="fitCenter"
        android:textColor="@color/colorWhite"
        android:layout_alignBottom="@+id/welcomeHeading"/>
    <androidx.appcompat.widget.AppCompatImageButton
        android:layout_margin="10dp"
        android:padding="10dp"
        android:id="@+id/permission_notification"
        android:layout_width="125dp"
        android:layout_height="50dp"
        android:background="@drawable/button_shape"
        android:scaleType="fitCenter"
        android:textColor="@color/colorWhite"
        android:layout_alignBottom="@+id/welcomeHeading"/>

</LinearLayout>