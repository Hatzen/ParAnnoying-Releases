<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_height="wrap_content"
        android:layout_width="match_parent"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/welcomeHeading"
            android:layout_margin="25dp"
            android:textColor="@color/colorWhite"
            android:textSize="28sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_above="@+id/welcomeText"
            android:gravity="center"
            android:layout_weight="1"/>
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatImageButton
        android:layout_margin="10dp"
        android:padding="10dp"
        android:id="@+id/chat_import"
        android:layout_width="125dp"
        android:layout_height="50dp"
        android:background="@drawable/button_shape"
        android:scaleType="fitCenter"
        android:textColor="@color/colorWhite"
        android:layout_alignBottom="@+id/welcomeHeading"/>

    <Button
        android:layout_margin="10dp"
        android:padding="10dp"
        android:id="@+id/dummy_import1"
        android:text="Test Device A"
        android:layout_width="125dp"
        android:layout_height="50dp"
        android:background="@drawable/button_shape"
        android:scaleType="fitCenter"
        android:textColor="@color/colorWhite"
        android:layout_alignBottom="@+id/welcomeHeading"/>

    <Button
        android:layout_margin="10dp"
        android:padding="10dp"
        android:text="Test Device B"
        android:id="@+id/dummy_import2"
        android:layout_width="125dp"
        android:layout_height="50dp"
        android:background="@drawable/button_shape"
        android:scaleType="fitCenter"
        android:textColor="@color/colorWhite"
        android:layout_alignBottom="@+id/welcomeHeading"/>

    <Button
        android:layout_margin="10dp"
        android:padding="10dp"
        android:text="Test Device C"
        android:id="@+id/dummy_import3"
        android:layout_width="125dp"
        android:layout_height="50dp"
        android:background="@drawable/button_shape"
        android:scaleType="fitCenter"
        android:textColor="@color/colorWhite"
        android:layout_alignBottom="@+id/welcomeHeading"/>

    <Button
        android:layout_margin="10dp"
        android:padding="10dp"
        android:text="Test Device D"
        android:id="@+id/dummy_import4"
        android:layout_width="125dp"
        android:layout_height="50dp"
        android:background="@drawable/button_shape"
        android:scaleType="fitCenter"
        android:textColor="@color/colorWhite"
        android:layout_alignBottom="@+id/welcomeHeading"/>

</LinearLayout>