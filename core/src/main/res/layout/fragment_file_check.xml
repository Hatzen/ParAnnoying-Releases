<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/container"
    android:orientation="vertical"
    android:padding="24dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?android:windowBackground">

    <TextView
        android:id="@+id/title"
        android:text="Superficial file check"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/result"
        android:layout_marginBottom="16dp"
        android:maxLines="7"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <ProgressBar
        android:id="@+id/loading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:indeterminate="true" />

    <!--
    Caution: Sharing files may put your entire system at risk.
    Warning: A single file exchange can undermine all your security measures.
    -->
    <TextView
        android:text="Caution: Sharing files may put your entire system at risk."
        android:textStyle="bold"
        android:textColor="@color/colorRed"
        android:layout_marginBottom="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <Button
        android:id="@+id/actionButton"
        android:text="Continue"
        android:layout_marginTop="24dp"
        android:layout_width="match_parent"
        android:layout_height="45dp" />
    <Button
        android:id="@+id/cancleButton"
        android:text="Cancle"
        android:layout_marginTop="7dp"
        android:layout_width="match_parent"
        android:layout_height="45dp" />
</LinearLayout>