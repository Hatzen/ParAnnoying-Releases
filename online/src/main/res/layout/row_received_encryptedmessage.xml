<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="55dp" >

    <TextView
        android:id="@+id/label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Incoming Message asasdasasd"
        android:layout_margin="15dp"
        android:textSize="20sp" >
    </TextView>

    <com.mikepenz.iconics.view.IconicsTextView
        android:text="{cmd-inbox-arrow-down} 17:51  21.05.2021"
        android:textColor="@color/colorAccent"
        android:id="@+id/inbox_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="100dp"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="9dp"
        android:layout_marginEnd="5dp"
        android:textSize="12sp">
    </com.mikepenz.iconics.view.IconicsTextView>

    <com.mikepenz.iconics.view.IconicsTextView
        android:text="{cmd-inbox-arrow-up-outline} 17:51  21.05.2021"
        android:textColor="@color/colorAccent"
        android:id="@+id/outbox_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="100dp"
        android:layout_alignParentEnd="true"
        android:layout_below="@id/inbox_time"
        android:layout_marginTop="7dp"
        android:layout_marginEnd="5dp"
        android:textSize="12sp">
    </com.mikepenz.iconics.view.IconicsTextView>

</RelativeLayout>